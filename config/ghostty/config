# OS-specific overrides live in an `os.conf` supplied by the per-OS stow layer
# (e.g. os/macos/config/ghostty/os.conf sets the macOS `command`). The leading
# `?` makes it optional: no error on machines where no os layer is stowed.
config-file = ?os.conf

confirm-close-surface = false

font-family = Hack FC Ligatured CCG
font-size = 12

theme = "tokyonight-moon"

shell-integration-features = no-cursor
cursor-style = block
cursor-style-blink = false

window-decoration = none
