powerline/coc
powerline/configstore/*
powerline/cr
powerline/htop
powerline/ninja-dev-sync.json
powerline/powerline

*/tmux/plugins/*
*/tmux/resurrect/

!*tmux/plugins/tpm/*

*.bak
config/fish/fish_variables

# Claude Code writes a project-local settings file into any repo it runs in;
# it's a per-machine session artifact, not dotfiles content.
/.claude/settings.local.json

shell/fish/completions
shell/fish/conf.d
shell/fish/functions
home/.tmux/plugins/*
!home/.tmux/plugins/tpm

# Claude Code: track ONLY hand-picked user-wide config.
# Everything else in the dir (secrets, credentials, caches, sessions,
# .claude.json, plugins, history, projects/) must never be committed.
config/.claude/*
!config/.claude/settings.json
!config/.claude/CLAUDE.md
!config/.claude/keybindings.json
!config/.claude/agents/
!config/.claude/commands/
!config/.claude/output-styles/
!config/.claude/hooks/
!config/.claude/skills/

# Antigravity/Gemini: track ONLY hand-picked user-wide config.
config/.gemini/*
!config/.gemini/settings.json
!config/.gemini/projects.json
!config/.gemini/trustedFolders.json
!config/.gemini/antigravity-cli/

config/.gemini/antigravity-cli/*
!config/.gemini/antigravity-cli/settings.json
!config/.gemini/antigravity-cli/mcp/
!config/.gemini/antigravity-cli/skills/
!config/.gemini/antigravity-cli/rules/
!config/.gemini/antigravity-cli/hooks/
!config/.gemini/antigravity-cli/plugins/
!config/.gemini/antigravity-cli/sidecars/

# KDE rewrites ksmserverrc on every logout with the session client IDs of
# whatever was open. It holds no settings at all -- only restart state -- so it
# conflicts forever and never carries anything worth restoring on a new machine.
os/arch/config/ksmserverrc

# install.sh generates the global git config per-machine into
# $XDG_CONFIG_HOME/git/config -- this directory once stowed. That is machine
# state; only `ignore` next to it belongs to the repo.
config/git/config
